# Copy to `.env` next to docker-compose.yml. Never commit .env.
#
# The owner key that unlocks ALL editing (creating trips, managing friends,
# approving seat requests). Sent by the frontend as the X-Admin-Key header.
# Use a long random string, e.g.  openssl rand -base64 24
ADMIN_KEY=change-me-to-a-long-random-secret
